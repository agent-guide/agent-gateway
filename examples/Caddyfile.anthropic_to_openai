# Caddy Agent Gateway
# Caddy App module ID: "agent_gateway"
# HTTP handler module IDs:
# - "http.handlers.agent_gateway_admin" (Caddyfile directive: "agent_gateway_admin")
# - "http.handlers.agent_route_dispatcher" (Caddyfile directive: "agent_route_dispatcher")
# Dispatcher LLM API module IDs:
# - "agent_route_dispatcher.llm_apis.openai"
# - "agent_route_dispatcher.llm_apis.anthropic"

{
	admin localhost:2019

	agent_gateway {
		config_store sqlite {
			path ./data/configstore.db
		}

		provider zhipu-simulated-openai {
			provider_type openai
			api_key {$ZHIPU_API_KEY}
			base_url https://open.bigmodel.cn/api/paas/v4
			default_model glm-4.7
			option debug_request true
		}

		provider deepseek-simulated-openai {
			provider_type openai
			api_key {$DEEPSEEK_API_KEY}
			base_url https://api.deepseek.com
			default_model deepseek-chat
			option debug_request true
		}

		virtualkey test-key {
			tag local-test
			name "Local Python test key"
			allowed_route anthropic-chat
		}

		route anthropic-chat {
			llm_api anthropic
			path_prefix /myanthropicprefix
			require_virtual_key
			allowed_model glm-4.7
			allowed_model glm-5.1
			allowed_model deepseek-chat
			target provider deepseek-simulated-openai
		}
	}
}

http://127.0.0.1:8019 {
	# Admin routes
	route /admin/* {
		agent_gateway_admin {
			admin_user default
			admin_password_hash $2a$14$Qxwz94t//fcaF.lyVzsIee0ZZuSNgS841WmLUo/NKGN5LlQzNg5Me # dummy
		}
	}
}

http://127.0.0.1:8080 {
	log {
		output stderr
		format console
	}

	# LLM API routes
	agent_route_dispatcher {
		llm_api openai
		llm_api anthropic
	}
}
